# ==========================================
# BACKEND ENVIRONMENT VARIABLES
# ==========================================

# 1. Express Server & Environment
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# 2. MongoDB Database
MONGO_URI=mongodb://localhost:27017/the-ever-house

# 3. JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# 4. Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# 5. Resend (Email Notifications)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=reservations@theeverhouse.com

# 6. Rate Limiting (Optional but recommended)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 7. Initial Admin Account (Optional for database seeding)
ADMIN_EMAIL=admin@everhouse.com
ADMIN_PASSWORD=secure_password_here
